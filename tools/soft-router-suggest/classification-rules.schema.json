{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/soft-router-suggest/classification-rules.v1.json",
  "title": "Classification Rules Schema",
  "description": "Dynamic classification rules for soft-router-suggest plugin - allows adding/removing categories without code changes",
  "type": "object",
  "required": ["version", "categories"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version for compatibility checking",
      "minimum": 1,
      "default": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp (ISO 8601)"
    },
    "notes": {
      "type": "string",
      "description": "Human-readable notes about this configuration"
    },
    "defaultFallback": {
      "type": "string",
      "description": "Default category ID to use when no match is found",
      "default": "fallback"
    },
    "categories": {
      "type": "array",
      "description": "List of classification categories (can be freely added/removed)",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "priority", "models"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique category identifier (snake_case recommended)",
            "pattern": "^[a-z][a-z0-9_]*$",
            "examples": ["complex_planning", "coding", "vision"]
          },
          "name": {
            "type": "string",
            "description": "Human-readable category name (bilingual recommended)",
            "examples": ["复杂规划设计", "代码任务 / Coding Tasks"]
          },
          "description": {
            "type": "string",
            "description": "Detailed description of this category's purpose"
          },
          "priority": {
            "type": "integer",
            "description": "Evaluation priority (higher = evaluated first). Used to resolve conflicts when multiple categories match.",
            "minimum": 0,
            "maximum": 1000,
            "default": 50
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this category is active",
            "default": true
          },
          "rules": {
            "type": "object",
            "description": "Matching rules for this category",
            "properties": {
              "positiveKeywords": {
                "type": "array",
                "description": "Keywords that indicate this category (case-insensitive)",
                "items": {
                  "type": "string"
                },
                "examples": [["方案", "规划", "设计", "planning", "architecture"]]
              },
              "negativeKeywords": {
                "type": "array",
                "description": "Keywords that exclude this category (case-insensitive)",
                "items": {
                  "type": "string"
                },
                "examples": [["写代码", "修bug", "write code", "debug"]]
              },
              "minLength": {
                "type": "integer",
                "description": "Minimum content length to consider this category",
                "minimum": 0
              },
              "maxLength": {
                "type": "integer",
                "description": "Maximum content length to consider this category",
                "minimum": 0
              },
              "metadataConditions": {
                "type": "object",
                "description": "Metadata-based matching conditions",
                "properties": {
                  "hasImage": {
                    "type": "boolean",
                    "description": "Requires image metadata to be present"
                  },
                  "hasCodeBlock": {
                    "type": "boolean",
                    "description": "Requires code block in content"
                  },
                  "customFields": {
                    "type": "object",
                    "description": "Custom metadata field checks",
                    "additionalProperties": true
                  }
                }
              },
              "regex": {
                "type": "array",
                "description": "Advanced regex patterns for matching (use with caution)",
                "items": {
                  "type": "object",
                  "required": ["pattern"],
                  "properties": {
                    "pattern": {
                      "type": "string",
                      "description": "JavaScript regex pattern"
                    },
                    "flags": {
                      "type": "string",
                      "description": "Regex flags (e.g., 'i' for case-insensitive)",
                      "default": "i"
                    }
                  }
                }
              }
            }
          },
          "confidence": {
            "type": "object",
            "description": "Confidence calculation rules",
            "properties": {
              "minSignals": {
                "type": "integer",
                "description": "Minimum number of signals required for 'medium' confidence",
                "minimum": 1,
                "default": 1
              },
              "highSignals": {
                "type": "integer",
                "description": "Number of signals required for 'high' confidence",
                "minimum": 1,
                "default": 2
              },
              "weights": {
                "type": "object",
                "description": "Signal weight configuration",
                "properties": {
                  "positiveKeyword": {
                    "type": "number",
                    "default": 1.0
                  },
                  "metadata": {
                    "type": "number",
                    "default": 2.0
                  },
                  "regex": {
                    "type": "number",
                    "default": 1.5
                  }
                }
              }
            }
          },
          "models": {
            "type": "array",
            "description": "Model priority list for this category (first available is used)",
            "minItems": 1,
            "items": {
              "type": "string",
              "description": "Model ID in 'provider/model' format",
              "pattern": "^[a-z0-9-]+/[a-z0-9-]+$",
              "examples": ["openai-codex/gpt-5.3-codex", "google-antigravity/gemini-3-flash"]
            }
          },
          "fallbackModel": {
            "type": "string",
            "description": "Specific fallback model when all models in 'models' array are unavailable",
            "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"
          }
        }
      }
    },
    "globalSettings": {
      "type": "object",
      "description": "Global classification settings",
      "properties": {
        "conflictResolution": {
          "type": "string",
          "enum": ["priority", "first_match", "highest_confidence"],
          "description": "How to resolve when multiple categories match",
          "default": "priority"
        },
        "defaultConfidence": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Default confidence when no signals detected",
          "default": "low"
        },
        "enableCache": {
          "type": "boolean",
          "description": "Cache classification results (per session)",
          "default": false
        },
        "cacheTtlMs": {
          "type": "integer",
          "description": "Cache TTL in milliseconds",
          "minimum": 0,
          "default": 60000
        }
      }
    }
  }
}
